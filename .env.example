# Copy to .env.local (never commit real keys).
# Vercel / Netlify / any host: add the SAME names in the project Environment Variables,
# then rebuild — Vite only exposes variables prefixed with VITE_ and inlines them at `vite build` time.

# Supabase (required for contacts, optional tables, and client-side anon access)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Rescue / SOS / Dead Man dispatch (edge function or rapid endpoint — see SOSPanel / Preflight resolver order)
VITE_RESCUE_EMAIL_URL=
# Optional alternate name used in some panels
VITE_RAPID_ENDPOINT_URL=
# HMAC signing key for rescue packets (must match edge function secret strategy)
VITE_RESCUE_SIGNING_KEY=

# Enable "Maps Embed API" for this key in Google Cloud Console.

VITE_GOOGLE_MAPS_API_KEY=

# Mapbox public token (pk.…) for tactical map raster tiles — same role as `titanium_mapbox_pk` in legacy HTML demos.
VITE_MAPBOX_ACCESS_TOKEN=

# MapTiler API key (required for basemaps). Each HUD layer maps to a fixed MapTiler style.json:
# streets → /maps/streets/, topo → /maps/topo/, outdoor → /maps/outdoor/, satellite → /maps/satellite/
# Prefer VITE_MAPTILER_KEY; VITE_MAPTILER_API_KEY and localStorage titanium_maptiler_key still work for demos.
VITE_MAPTILER_KEY=
VITE_MAPTILER_API_KEY=
